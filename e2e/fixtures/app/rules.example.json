[
  {
    "name": "rewrite-httpbin-get",
    "enabled": true,
    "host": "httpbin.org",
    "path": "/get",
    "status": 418,
    "message": "I'm a teapot",
    "headers": {
      "Content-Type": "application/json; charset=utf-8",
      "X-Rewritten-By": "forja"
    },
    "bodyObject": {
      "rewritten": true,
      "hello": "from forja",
      "note": "if you see this body with HTTP 418, the tool is working"
    }
  }
]
